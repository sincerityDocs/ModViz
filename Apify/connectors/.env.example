# ─────────────────────────────────────────────
# ModViz / Apify Connectors — Required Secrets
# Add these to: GitHub repo → Settings → Secrets and variables → Actions
# ─────────────────────────────────────────────

# Apify API token (required for all connectors)
# Get from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# GitHub bot token for auto-creating issues on failure
# Needs: repo:issues permission
# Create at: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_BOT_TOKEN=your_github_token_here

# Slack incoming webhook URL for failure alerts
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Datacenter proxy URL (optional — omit to run without proxy)
# Format: http://user:pass@proxy-host:port
# Or use Apify proxy: https://proxy.apify.com
DATACENTER_PROXY_URL=http://user:pass@your-proxy:8080

# ─────────────────────────────────────────────
# Per-run input (set when running connectors)
# ─────────────────────────────────────────────

# The product search query to pass to the connector
SEARCH_QUERY=wireless earbuds
